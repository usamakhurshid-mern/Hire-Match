NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://hirematch:hirematch@localhost:5432/hirematch
REDIS_URL=redis://localhost:6379

# RapidAPI — copy from Studio > Hub Listing > Gateway tab
RAPIDAPI_PROXY_SECRET=your-proxy-secret-here

# Set false to allow direct API access during local dev
REQUIRE_RAPIDAPI_PROXY=false

# Optional: run migrations on startup
RUN_MIGRATIONS=true

LOG_LEVEL=info
